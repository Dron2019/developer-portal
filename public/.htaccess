Options -MultiViews -Indexes -Includes
ServerSignature Off

# ---------------------------------------------------------------
# Security Headers
# ---------------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.github.com;"

    # Remove server version info
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# ---------------------------------------------------------------
# Block access to sensitive files & directories
# ---------------------------------------------------------------
<FilesMatch "(^\.env|\.env\..+|composer\.(json|lock)|package(-lock)?\.json|phpunit\.xml|artisan|webpack\.mix\.js|vite\.config\.(js|ts))$">
    Require all denied
</FilesMatch>

<FilesMatch "\.(log|sh|bak|swp|sql|sqlite|pem|key)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(app|bootstrap|config|database|resources|routes|src|storage|tests|vendor)(/|$) - [F,L]
</IfModule>

# ---------------------------------------------------------------
# Static asset caching (Vite adds content hash to filenames)
# ---------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On

    # Hashed assets — cache forever
    <FilesMatch "\.(js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|gif|ico|webp|avif)$">
        ExpiresDefault "access plus 1 year"
        Header append Cache-Control "public, immutable"
    </FilesMatch>

    # Entry points — never cache, always revalidate
    <FilesMatch "^(index\.html|index\.php)$">
        ExpiresDefault "access plus 0 seconds"
        Header set Cache-Control "no-store, no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>

# ---------------------------------------------------------------
# Compression
# ---------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/xml text/xml
    AddOutputFilterByType DEFLATE image/svg+xml font/woff2
</IfModule>

# ---------------------------------------------------------------
# URL Rewriting
# ---------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Pass Authorization header to PHP
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Remove trailing slashes (except directories)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Serve existing static files directly (assets, images, fonts…)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Everything else → Laravel front controller
    # Laravel router handles /api/* routes; web.php catch-all serves the React SPA
    RewriteRule ^ index.php [L]
</IfModule>
