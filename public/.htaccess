Options -MultiViews -Indexes -Includes
ServerSignature Off

# ---------------------------------------------------------------
# Security Headers
# ---------------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

    # Remove server version info
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# ---------------------------------------------------------------
# Block access to sensitive files
# ---------------------------------------------------------------
<FilesMatch "(^\.env|\.env\..+|composer\.(json|lock)|package\.json|phpunit\.xml|artisan)$">
    Require all denied
</FilesMatch>

<FilesMatch "\.(log|sh|bak|swp|sql)$">
    Require all denied
</FilesMatch>

# ---------------------------------------------------------------
# Static asset caching (React build files)
# ---------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On

    # Cache-busted assets (Vite adds content hash to filenames)
    <FilesMatch "\.(js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|gif|ico|webp)$">
        ExpiresDefault "access plus 1 year"
        Header append Cache-Control "public, immutable"
    </FilesMatch>

    # Never cache index files
    <FilesMatch "^(index\.html|index\.php)$">
        ExpiresDefault "access plus 0 seconds"
        Header set Cache-Control "no-store, no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>

# ---------------------------------------------------------------
# Compression
# ---------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/xml text/xml
    AddOutputFilterByType DEFLATE image/svg+xml font/woff2
</IfModule>

# ---------------------------------------------------------------
# URL Rewriting
# ---------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Pass Authorization and XSRF headers to PHP
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove trailing slashes (except directories)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Route /api/* and /sanctum/* to Laravel front controller
    RewriteCond %{REQUEST_URI} ^/(api|sanctum)/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]

    # Serve existing static files directly (React assets, images, fonts…)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # All other routes → React SPA (index.html)
    # index.html must be copied from frontend/dist into backend/public/
    RewriteRule ^ index.html [L]
</IfModule>
